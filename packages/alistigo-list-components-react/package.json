{
  "name": "@alistigo/list-components-react",
  "version": "0.2.3",
  "license": "MIT",
  "author": {
    "name": "Mikael Labrut",
    "email": "contact@alistigo.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alistigo/holos.git",
    "directory": "packages/alistigo-list-components-react"
  },
  "bugs": {
    "url": "https://github.com/alistigo/holos/issues"
  },
  "homepage": "https://github.com/alistigo/holos/tree/main/packages/alistigo-list-components-react#readme",
  "keywords": [
    "alistigo",
    "list",
    "react",
    "components",
    "ui",
    "tailwind"
  ],
  "private": false,
  "type": "module",
  "description": "React presentational components for the Alistigo base list app — built on the repo's chosen stack (Tailwind v4 + Radix Primitives + Vaul + Motion + Lucide + Radix Colors + Lingui i18n). Pinned to the driver-playwright contract; ships its own Storybook for component review.",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./src/styles/globals.css",
    "./locales/*": "./src/locales/*"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/styles/globals.css",
    "src/locales"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "i18n:extract": "pnpm -w run i18n:extract",
    "i18n:compile": "pnpm -w run i18n:compile"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "dependencies": {
    "@alistigo/logger": "workspace:*",
    "@lingui/core": "^6.0.0",
    "@lingui/react": "^6.0.0",
    "@alistigo/document-editor": "workspace:*",
    "@alistigo/document-format": "workspace:*",
    "@alistigo/domain": "workspace:*",
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.456.0",
    "motion": "^11.18.2",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@lingui/babel-plugin-lingui-macro": "^6.0.0",
    "@lingui/cli": "^6.0.0",
    "@lingui/format-po": "^6.0.0",
    "@lingui/vite-plugin": "^6.0.0",
    "@storybook/react-vite": "^10.3.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "storybook": "^10.3.0",
    "tailwindcss": "^4.0.0",
    "vite": "^7.0.0"
  }
}
