{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["app"],
  "properties": {
    "app": { "type": "string" },
    "lang": { "type": "string" },
    "plugins": {
      "type": "object",
      "additionalProperties": { "type": "object" }
    }
  },
  "if": {
    "properties": { "app": { "const": "@alistigo/artifact-list" } }
  },
  "then": {
    "properties": {
      "app": { "type": "string" },
      "lang": { "type": "string" },
      "readonly": { "type": "boolean", "default": false },
      "plugins": {
        "type": "object",
        "additionalProperties": { "type": "object" }
      }
    },
    "additionalProperties": false
  },
  "else": {
    "additionalProperties": true
  }
}
