      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schemas/document.json": "./src/schemas/document.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/schemas",
    "docs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@alistigo/domain": "workspace:*",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1"
  }
