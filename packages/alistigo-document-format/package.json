    "email": "contact@alistigo.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alistigo/holos.git",
    "directory": "packages/alistigo-document-format"
  },
  "bugs": {
    "url": "https://github.com/alistigo/holos/issues"
  },
  "homepage": "https://github.com/alistigo/holos/tree/main/packages/alistigo-document-format#readme",
  "keywords": [
    "alistigo",
    "list",
    "document",
    "json-schema",
    "json-ld",
    "typescript"
  ],
  "private": false,
  "type": "module",
