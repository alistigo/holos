{
  "name": "alistigo-artifact-list-skill",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/references"],
      "inputs": [
        "{workspaceRoot}/packages/alistigo-document-format/docs/spec.md",
        "{workspaceRoot}/packages/alistigo-artifact-config-list-format/README.md"
      ],
      "options": {
        "command": "bun scripts/build-references.ts",
        "cwd": "packages/alistigo-artifact-list-skill"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome check .",
        "cwd": "packages/alistigo-artifact-list-skill"
      }
    }
  }
}
